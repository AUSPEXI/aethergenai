    { "name": "user_tier", "type": "string", "privacy": "low" },
    { "name": "social_platform", "type": "string", "privacy": "low" },
    { "name": "platform_chatgpt", "type": "number", "privacy": "low" },
    { "name": "platform_perplexity", "type": "number", "privacy": "low" },
